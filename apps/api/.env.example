# Local dev: Postgres (Docker/Neon) hoặc URL từ Railway Postgres plugin
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

JWT_SECRET="change-me-in-production-use-long-random-string"
PORT=3001

