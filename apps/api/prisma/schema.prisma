generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  TEACHER
  STUDENT
}

enum TrashCategory {
  ORGANIC
  RECYCLE
  OTHER
}

enum WheelPrizeType {
  POINTS
  SPIN
  ITEM
  VOUCHER
}

enum WheelMissionKey {
  SORT_CORRECT
  DAILY_LOGIN
  PLAY_SORT
}

model Organization {
  id           String         @id @default(cuid())
  name         String
  createdAt    DateTime       @default(now())
  classes      Class[]
  users        User[]
  trashItems   TrashItem[]
  quizConfig   QuizConfig?
  quizQuestions QuizQuestion[]
  wheelConfig  WheelConfig?
  wheelPrizes  WheelPrize[]
  wheelMissions WheelMission[]
}

model Class {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teacherId      String?
  teacher        User?    @relation("ClassTeacher", fields: [teacherId], references: [id])
  students       User[]   @relation("ClassStudents")
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  fullName       String
  role           Role      @default(STUDENT)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  classId        String?
  class          Class?    @relation("ClassStudents", fields: [classId], references: [id])
  teachingClasses Class[]  @relation("ClassTeacher")
  greenPoints    Int       @default(0)
  sessions       GameSession[]
  quizSessions   QuizSession[]
  quizQuestions  QuizQuestion[]
  auditLogs      AuditLog[]
  wheelDaily     UserWheelDaily[]
  wheelSpins     WheelSpinLog[]
  createdAt      DateTime  @default(now())

  @@index([organizationId])
  @@index([classId])
}

model TrashItem {
  id             String        @id @default(cuid())
  name           String
  emoji          String
  imageUrl       String?
  category       TrashCategory
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  isGlobal       Boolean       @default(false)
  active         Boolean       @default(true)
  answers        GameAnswer[]

  @@index([organizationId])
}

model GameSession {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  score        Int          @default(0)
  correctCount Int          @default(0)
  totalCount   Int          @default(0)
  durationSec  Int          @default(45)
  startedAt    DateTime     @default(now())
  finishedAt   DateTime?
  answers      GameAnswer[]

  @@index([userId])
}

model GameAnswer {
  id          String        @id @default(cuid())
  sessionId   String
  session     GameSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  itemId      String
  item        TrashItem     @relation(fields: [itemId], references: [id])
  binChosen   TrashCategory
  isCorrect   Boolean
  pointsDelta Int

  @@index([sessionId])
}

model Mission {
  id             String   @id @default(cuid())
  title          String
  description    String
  targetPlays    Int      @default(1)
  rewardPoints   Int      @default(20)
  organizationId String?
  classId        String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
  action    String
  target    String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([actorId])
}

model QuizConfig {
  id                 String       @id @default(cuid())
  organizationId     String       @unique
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  secondsPerQuestion Int          @default(10)
  questionsPerRound  Int          @default(10)
  updatedAt          DateTime     @updatedAt
}

model QuizQuestion {
  id             String       @id @default(cuid())
  question       String
  optionA        String
  optionB        String
  optionC        String
  optionD        String
  correctOption  String
  explanation    String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id])
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  answers        QuizAnswer[]

  @@index([organizationId])
}

model QuizSession {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  score              Int          @default(0)
  correctCount       Int          @default(0)
  totalCount         Int          @default(0)
  secondsPerQuestion Int
  questionIds        String
  startedAt          DateTime     @default(now())
  finishedAt         DateTime?
  answers            QuizAnswer[]

  @@index([userId])
}

model QuizAnswer {
  id          String       @id @default(cuid())
  sessionId   String
  session     QuizSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId  String
  question    QuizQuestion @relation(fields: [questionId], references: [id])
  chosen      String
  isCorrect   Boolean
  pointsDelta Int
  answeredAt  DateTime     @default(now())

  @@index([sessionId])
}

model WheelConfig {
  id                  String       @id @default(cuid())
  organizationId      String       @unique
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dailyFreeSpins      Int          @default(3)
  resetHour           Int          @default(0)
  extraSpinsEnabled   Boolean      @default(true)
  maxExtraSpinsPerDay Int          @default(5)
  bonusEverySpins     Int          @default(3)
  updatedAt           DateTime     @updatedAt
}

model WheelPrize {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  type           WheelPrizeType
  value          Int            @default(0)
  weight         Int            @default(10)
  color          String         @default("#10b981")
  icon           String?
  active         Boolean        @default(true)
  sortOrder      Int            @default(0)
  spins          WheelSpinLog[]

  @@index([organizationId])
}

model WheelMission {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String
  missionKey     WheelMissionKey
  targetCount    Int             @default(1)
  rewardSpins    Int             @default(1)
  active         Boolean         @default(true)
  sortOrder      Int             @default(0)

  @@index([organizationId])
}

model UserWheelDaily {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateKey          String
  spinsRemaining   Int      @default(0)
  spinsUsedToday   Int      @default(0)
  spinsTowardBonus Int      @default(0)
  extraSpinsEarned Int      @default(0)
  missionProgress  String   @default("{}")
  missionsClaimed  String   @default("[]")

  @@unique([userId, dateKey])
  @@index([userId])
}

model WheelSpinLog {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  prizeId   String?
  prize     WheelPrize?    @relation(fields: [prizeId], references: [id], onDelete: SetNull)
  prizeName String
  prizeType WheelPrizeType
  value     Int            @default(0)
  createdAt DateTime       @default(now())

  @@index([userId])
  @@index([createdAt])
}
